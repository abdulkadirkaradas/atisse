{
  "name": "@atisse/core",
  "version": "1.0.0",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "import": "./dist/testing/mock-provider.js",
      "types": "./dist/testing/mock-provider.d.ts",
      "require": "./dist/testing/mock-provider.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "author": "Abdulkadir Karadas(saferias)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdulkadirkaradas/atisse.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/abdulkadirkaradas/atisse/issues"
  },
  "homepage": "https://github.com/abdulkadirkaradas/atisse#readme",
  "keywords": [
    "llm",
    "ai",
    "orchestration",
    "execution-kernel",
    "lifecycle",
    "state-machine",
    "typescript",
    "provider"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsup"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "vitest": "^4.1.8"
  }
}
