{
  "name": "@atisse/memory-inmemory",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
