{
  "name": "@atisse/core",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:all": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "typecheck:all": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "test:coverage": "pnpm --recursive test:coverage",
    "build": "pnpm --recursive build",
    "docs": "typedoc --out docs/api src/index.ts || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
