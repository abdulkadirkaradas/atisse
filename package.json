{
  "name": "atisse",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:all": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "typecheck:all": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "test:coverage": "pnpm --recursive test:coverage",
    "build": "pnpm --recursive build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "bench": "npx tsx scripts/benchmark.ts",
    "docs": "typedoc --out docs/api packages/core/src/index.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
