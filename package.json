{
  "name": "@atisse/core",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:all": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "typecheck:all": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "test:coverage": "pnpm --recursive test:coverage",
    "build": "pnpm --recursive build",
    "docs": "typedoc --out docs/api src/index.ts || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.26.11",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}
